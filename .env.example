# Google reCAPTCHA v3
RECAPTCHA_SECRET_KEY=your_recaptcha_secret_key_here

# Resend (https://resend.com)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# OTP hashing salt (any random string)
OTP_SALT=change-this-to-a-random-string-2026

# Email addresses
CONTACT_EMAIL=info@totalcloudai.com
FROM_EMAIL=noreply@totalcloudai.com

# CORS (set to your domain in production)
ALLOWED_ORIGIN=https://totalcloudai.com

# Node environment
NODE_ENV=development
